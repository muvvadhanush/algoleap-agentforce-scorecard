generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Assessment {
  id        String   @id @default(uuid())
  shareId   String   @unique @default(uuid())
  firstName String
  lastName  String
  email     String
  company   String?
  jobTitle  String?
  phone     String?
  persona   String
  score     Int
  tier      String
  scores    Json
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([shareId])
  @@index([createdAt])
}
